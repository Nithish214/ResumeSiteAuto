# Copy this file to ".env" and fill in your real values.

# MongoDB connection string.
# Local example:  mongodb://127.0.0.1:27017/resume-website
# Atlas example:  mongodb+srv://<user>:<password>@cluster0.mongodb.net/resume-website
MONGO_URI=mongodb://127.0.0.1:27017/resume-website

# Port the Express API listens on (local dev only - Lambda ignores this)
PORT=5000

# The origin(s) your React dev server / production site run on.
# Comma-separate multiple origins to allow local dev AND production at once:
CLIENT_URL=http://localhost:5173,https://nithishnarravula.dev

# --- Admin authentication (JWT) ---------------------------------------
# There's no admin user database - credentials live here as env vars,
# which is enough for a single-admin site.
#
# ADMIN_USERNAME: pick anything, e.g. "admin"
# ADMIN_PASSWORD_HASH: NEVER put a plain-text password here. Generate the
#   hash with:  npm run hash-password -- YourRealPassword
#   then paste the printed value below.
# JWT_SECRET: any long random string, used to sign login tokens. Generate
#   one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
JWT_SECRET=

# --- Email notifications (optional) -----------------------------------
# Leave these blank to skip email notifications entirely - the contact
# form still works and still saves to MongoDB either way.
#
# EMAIL_USER/EMAIL_PASS: a Gmail address + App Password (NOT your normal
#   Gmail password). Generate one at myaccount.google.com/apppasswords
#   (requires 2-Step Verification enabled on that Google account).
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=
EMAIL_FROM_NAME=Resume Website

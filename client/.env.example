# Copy this file to ".env" and adjust if needed.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Base URL of the Express API (see server/server.js)
VITE_API_URL=http://localhost:5000/api

# NOTE: there is no admin password here anymore. Admin login now goes
# through a real backend endpoint (POST /api/auth/login) that checks
# credentials against ADMIN_USERNAME/ADMIN_PASSWORD_HASH in server/.env -
# see that file's comments for how to set those up. The client never
# stores or checks a password itself, which is what makes this real
# authentication instead of the old client-side-only check.

